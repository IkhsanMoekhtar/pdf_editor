# Backend
PORT=8787
MAX_UPLOAD_MB=200
TRUST_PROXY=1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Frontend
# Leave empty for local Vite proxy (/api -> localhost:8787)
# Set this in production frontend deploys, e.g. https://your-space-name.hf.space
# If your Hugging Face Space is private, set VITE_HF_TOKEN so frontend can send
# Authorization: Bearer <token> automatically for requests to .hf.space.
VITE_API_BASE_URL=
VITE_HF_TOKEN=
